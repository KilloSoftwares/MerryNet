# ============================================================
# Maranet — Root Environment Variables (Docker Compose)
# ============================================================
# This file is used by docker-compose.yml for production deployments.
# Copy this file to .env and configure for your environment.
# NEVER commit .env to version control!

# ============================================================
# JWT Security
# ============================================================
# Generate a strong random secret for production
# Example: openssl rand -base64 64
JWT_SECRET=change-this-in-production-to-a-random-secret

# ============================================================
# M-Pesa (Safaricom Daraja API)
# ============================================================
# Get these from https://developer.safaricom.co.ke/
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_PASS_KEY=your-pass-key
MPESA_CALLBACK_URL=https://api.maranet.app/api/v1/payments/mpesa/callback
MPESA_ENVIRONMENT=sandbox
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# ============================================================
# WireGuard Gateway
# ============================================================
# Generate with: wg genkey
GATEWAY_WG_PRIVATE_KEY=your-wireguard-private-key-here

# ============================================================
# Grafana Monitoring
# ============================================================
# Change this to a strong password in production
GRAFANA_PASSWORD=maranet-admin

# ============================================================
# PostgreSQL Database
# ============================================================
# Change these to strong credentials in production
POSTGRES_DB=maranet
POSTGRES_USER=maranet
POSTGRES_PASSWORD=maranet_secret

# ============================================================
# Redis
# ============================================================
REDIS_PASSWORD=