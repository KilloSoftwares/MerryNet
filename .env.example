# ============================================================
# Maranet Zero — Environment Configuration
# ============================================================
# Copy this file to .env and fill in all required values.
# See ENV_SETUP_GUIDE.md for detailed instructions.
# ============================================================

# ============================================================
# Required: Database Credentials
# ============================================================
# Generate a strong password: openssl rand -base64 32
POSTGRES_DB=maranet
POSTGRES_USER=maranet
POSTGRES_PASSWORD=<GENERATE_A_STRONG_PASSWORD>

# ============================================================
# Required: JWT Secret
# ============================================================
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=<GENERATE_A_STRONG_SECRET_64_CHARS>

# ============================================================
# Required: Redis Password
# ============================================================
# Generate a strong password: openssl rand -base64 24
REDIS_PASSWORD=<GENERATE_A_STRONG_PASSWORD>

# ============================================================
# Required: WireGuard Private Key
# ============================================================
# Generate a key: wg genkey
GATEWAY_WG_PRIVATE_KEY=<GENERATE_WIREGUARD_PRIVATE_KEY>

# ============================================================
# Required: Grafana Admin Password
# ============================================================
# Generate a strong password: openssl rand -base64 24
GRAFANA_PASSWORD=<GENERATE_A_STRONG_PASSWORD>

# ============================================================
# Required for Payments: M-Pesa Credentials
# ============================================================
# Get these from https://developer.safaricom.co.ke/
# For production, use production credentials (not sandbox)
MPESA_CONSUMER_KEY=<YOUR_MPESA_CONSUMER_KEY>
MPESA_CONSUMER_SECRET=<YOUR_MPESA_CONSUMER_SECRET>
MPESA_PASS_KEY=<YOUR_MPESA_PASS_KEY>
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_CALLBACK_URL=https://api.maranet.app/api/v1/payments/mpesa/callback
MPESA_ENVIRONMENT=production
MPESA_BASE_URL=https://api.safaricom.co.ke

# ============================================================
# Optional: Cognitive API Key
# ============================================================
# Change from default 'twin-dev-key' in production
COGNITIVE_API_KEY=<GENERATE_A_STRONG_API_KEY>

# ============================================================
# Notes:
# - Never commit your .env file to version control
# - Use different credentials for development and production
# - Rotate secrets regularly (every 90 days recommended)
# - Store production secrets in a secrets manager (Vault, etc.)
# ============================================================