# ============================================================
# Maranet Gateway Service — Environment Variables (Example)
# ============================================================
# Copy this file to .env and configure for your environment.
# NEVER commit .env to version control!

# Node Identity
NODE_ID=gateway-001

# WireGuard Configuration
WG_INTERFACE=wg0
WG_LISTEN_PORT=51820
WG_PRIVATE_KEY=your-wireguard-private-key-here
WG_ADDRESS=10.0.0.1/16
WG_DNS=1.1.1.1,8.8.8.8
WG_MTU=1420
WG_PERSISTENT_KEEPALIVE=25

# gRPC Server
GRPC_HOST=0.0.0.0
GRPC_PORT=50052

# NAT Configuration
NAT_EXTERNAL_INTERFACE=eth0
NAT_INTERNAL_SUBNET=10.0.0.0/16
NAT_ENABLE_FORWARDING=true

# Metrics
METRICS_PORT=9091