# ============================================================
# Maranet Zero — Environment Variables Template
# ============================================================

# Node
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://maranet:{{ lookup('env', 'DB_PASSWORD') | default('maranet_secret', true) }}@localhost:5432/maranet?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET={{ lookup('env', 'JWT_SECRET') | default('change-me-in-production', true) }}
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# gRPC
GRPC_PORT=50051
GRPC_HOST=0.0.0.0
GATEWAY_HOST=192.168.1.102
GATEWAY_GRPC_PORT=50052

# M-Pesa (Daraja API)
MPESA_CONSUMER_KEY={{ lookup('env', 'MPESA_CONSUMER_KEY') }}
MPESA_CONSUMER_SECRET={{ lookup('env', 'MPESA_CONSUMER_SECRET') }}
MPESA_BUSINESS_SHORT_CODE={{ lookup('env', 'MPESA_BUSINESS_SHORT_CODE') | default('174379', true) }}
MPESA_PASS_KEY={{ lookup('env', 'MPESA_PASS_KEY') }}
MPESA_CALLBACK_URL=https://api.maranet.app/api/v1/payments/mpesa/callback
MPESA_ENVIRONMENT=production
MPESA_BASE_URL=https://api.safaricom.co.ke

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=*

# Commission
DEFAULT_COMMISSION_RATE=0.20
