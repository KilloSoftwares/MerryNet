# ============================================================
# Maranet Reseller Agent — Environment Variables (Example)
# ============================================================
# Copy this file to .env and configure for your environment.
# NEVER commit .env to version control!

# Device Identity
DEVICE_ID=node-001
PLATFORM=rpi

# Main Server Connection
SERVER_ADDRESS=localhost:50051
SERVER_USE_TLS=false
SERVER_CERT_FILE=

# WireGuard Configuration
WG_INTERFACE=wg0
WG_LISTEN_PORT=51820
WG_PRIVATE_KEY=your-wireguard-private-key-here
WG_ADDRESS=10.0.1.1/24
WG_DNS=1.1.1.1,8.8.8.8
WG_MTU=1420

# Database (SQLite)
DB_PATH=/var/lib/maranet/agent.db

# Health Monitoring
HEARTBEAT_INTERVAL=30

# Local API
LOCAL_API_ENABLED=true
LOCAL_API_OPEN_MODE=false
LOCAL_API_PORT=8080
MAIN_SERVER_PUBLIC_KEY=

# Developer Mode (enables debug logging and open mode)
DEVELOPER_MODE=false