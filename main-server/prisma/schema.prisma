// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Users
// ============================================================

model User {
  id                   String         @id @default(uuid()) @db.Uuid
  phone                String         @unique @db.VarChar(20)
  passwordHash         String?        @map("password_hash")
  pin                  String?        @db.VarChar(6) // OTP pin
  pinExpiresAt         DateTime?      @map("pin_expires_at")
  referralCode         String?        @unique @map("referral_code") @db.VarChar(10)
  referredBy           String?        @map("referred_by") @db.VarChar(10)
  autoRenew            Boolean        @default(false) @map("auto_renew")
  isActive             Boolean        @default(true) @map("is_active")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  lastLoginAt          DateTime?      @map("last_login_at")

  // Relations
  subscriptions        Subscription[]
  transactions         Transaction[]
  reseller             Reseller?
  refreshTokens        RefreshToken[]
  activeSubscription   Subscription?  @relation("ActiveSubscription", fields: [activeSubscriptionId], references: [id])
  activeSubscriptionId String?        @unique @map("active_subscription_id") @db.Uuid
  episodes             Episode[]
  cognitiveState       CognitiveState?

  @@map("users")
}

// ============================================================
// Resellers
// ============================================================

model Reseller {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @unique @map("user_id") @db.Uuid
  deviceId          String       @unique @map("device_id") @db.VarChar(100)
  publicKey         String?      @map("public_key")
  endpoint          String?      @db.VarChar(255)
  location          String?      @db.VarChar(100)
  capacity          Int          @default(100)
  activePeers       Int          @default(0) @map("active_peers")
  lastSeen          DateTime?    @map("last_seen")
  isOnline          Boolean      @default(false) @map("is_online")
  isDevNode         Boolean      @default(false) @map("is_dev_node")
  compensationType  CompensationType @default(COMMISSION) @map("compensation_type")
  freeNetPlanId     String?      @map("free_net_plan_id") @db.VarChar(50)
  commissionRate    Decimal      @default(20.00) @map("commission_rate") @db.Decimal(5, 2)
  totalEarnings     Decimal      @default(0) @map("total_earnings") @db.Decimal(12, 2)
  assignedSubnet    String?      @map("assigned_subnet") @db.VarChar(50)
  version           String?      @db.VarChar(20)
  platform          String?      @db.VarChar(20)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  // Relations
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions     Subscription[]
  commissions       Commission[]
  nodeMetrics       NodeMetric[]

  @@map("resellers")
}

enum CompensationType {
  COMMISSION
  FREE_NET
  DEVELOPER

  @@map("compensation_type")
}

// ============================================================
// Plans
// ============================================================

model Plan {
  id           String        @id @db.VarChar(50)
  name         String        @db.VarChar(100)
  description  String?
  price        Decimal       @db.Decimal(10, 2)
  currency     String        @default("KES") @db.VarChar(3)
  durationHours Int          @map("duration_hours")
  isActive     Boolean       @default(true) @map("is_active")
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at")

  // Relations
  subscriptions Subscription[]
  transactions  Transaction[]

  @@map("plans")
}

// ============================================================
// Subscriptions (Time-Based, Unlimited Data)
// ============================================================

model Subscription {
  id           String            @id @default(uuid()) @db.Uuid
  userId       String            @map("user_id") @db.Uuid
  planId       String            @map("plan_id") @db.VarChar(50)
  resellerId   String?           @map("reseller_id") @db.Uuid
  startTime    DateTime          @default(now()) @map("start_time")
  endTime      DateTime          @map("end_time")
  status       SubscriptionStatus @default(ACTIVE)
  autoRenew    Boolean           @default(false) @map("auto_renew")
  peerPublicKey String?          @map("peer_public_key")
  peerIp       String?           @map("peer_ip") @db.VarChar(50)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  // Relations
  user         User              @relation(fields: [userId], references: [id])
  plan         Plan              @relation(fields: [planId], references: [id])
  reseller     Reseller?         @relation(fields: [resellerId], references: [id])
  transaction  Transaction?
  activeUser   User?             @relation("ActiveSubscription")

  @@index([userId])
  @@index([resellerId])
  @@index([status, endTime])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED

  @@map("subscription_status")
}

// ============================================================
// Transactions
// ============================================================

model Transaction {
  id                String            @id @default(uuid()) @db.Uuid
  userId            String            @map("user_id") @db.Uuid
  subscriptionId    String?           @unique @map("subscription_id") @db.Uuid
  planId            String?           @map("plan_id") @db.VarChar(50)
  mpesaCode         String?           @unique @map("mpesa_code") @db.VarChar(50)
  merchantRequestId String?           @map("merchant_request_id") @db.VarChar(100)
  checkoutRequestId String?           @unique @map("checkout_request_id") @db.VarChar(100)
  amount            Decimal           @db.Decimal(10, 2)
  currency          String            @default("KES") @db.VarChar(3)
  phone             String?           @db.VarChar(20)
  status            TransactionStatus @default(PENDING)
  resultCode        Int?              @map("result_code")
  resultDesc        String?           @map("result_desc")
  transactionDate   DateTime?         @map("transaction_date")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  user              User              @relation(fields: [userId], references: [id])
  subscription      Subscription?     @relation(fields: [subscriptionId], references: [id])
  plan              Plan?             @relation(fields: [planId], references: [id])
  commission        Commission?

  @@index([userId])
  @@index([status])
  @@index([checkoutRequestId])
  @@map("transactions")
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED

  @@map("transaction_status")
}

// ============================================================
// Commissions
// ============================================================

model Commission {
  id             String    @id @default(uuid()) @db.Uuid
  resellerId     String    @map("reseller_id") @db.Uuid
  transactionId  String    @unique @map("transaction_id") @db.Uuid
  amount         Decimal   @db.Decimal(10, 2)
  paid           Boolean   @default(false)
  paidAt         DateTime? @map("paid_at")
  payoutMpesaCode String?  @map("payout_mpesa_code") @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  reseller       Reseller     @relation(fields: [resellerId], references: [id])
  transaction    Transaction  @relation(fields: [transactionId], references: [id])

  @@index([resellerId])
  @@index([paid])
  @@map("commissions")
}

// ============================================================
// Refresh Tokens
// ============================================================

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================
// Node Metrics (time-series)
// ============================================================

model NodeMetric {
  id          String   @id @default(uuid()) @db.Uuid
  resellerId  String   @map("reseller_id") @db.Uuid
  activePeers Int      @map("active_peers")
  cpuUsage    Float    @map("cpu_usage")
  memoryUsage Float    @map("memory_usage")
  bytesRx     BigInt   @map("bytes_rx")
  bytesTx     BigInt   @map("bytes_tx")
  uptime      Float
  recordedAt  DateTime @default(now()) @map("recorded_at")

  // Relations
  reseller    Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  @@index([resellerId, recordedAt])
  @@map("node_metrics")
}

// ============================================================
// Cognitive Episodes (Memory System)
// ============================================================

model Episode {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  sessionId  String       @map("session_id") @db.VarChar(100)
  type       String       @default("episodic") @db.VarChar(50)
  content    String       @db.Text
  metadata   Json?
  importance Float        @default(0.5)
  createdAt  DateTime     @default(now()) @map("created_at")

  // Relations
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
  @@map("episodes")
}

// ============================================================
// Cognitive States (Personality & Emotion)
// ============================================================

model CognitiveState {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  personalityData Json?    @map("personality_data")
  emotionData     Json?    @map("emotion_data")
  lastUpdated     DateTime @updatedAt @map("last_updated")

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cognitive_states")
}

// ============================================================
// OTP Codes (for phone verification)
// ============================================================

model OtpCode {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String   @db.VarChar(20)
  code      String   @db.VarChar(6)
  purpose   String   @default("login") @db.VarChar(20) // login, verify, reset
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone, code])
  @@index([expiresAt])
  @@map("otp_codes")
}
