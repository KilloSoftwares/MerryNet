# ============================================================
# Maranet Zero — Main Server Environment Variables
# ============================================================

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://maranet:maranet_secret@localhost:5432/maranet?schema=public

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# M-Pesa (Safaricom Daraja API)
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_PASS_KEY=your-pass-key
MPESA_CALLBACK_URL=https://api.maranet.app/api/v1/payments/mpesa/callback
MPESA_ENVIRONMENT=sandbox
# sandbox: https://sandbox.safaricom.co.ke
# production: https://api.safaricom.co.ke
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# gRPC
GRPC_PORT=50051
GRPC_HOST=0.0.0.0

# WireGuard Gateway
GATEWAY_HOST=localhost
GATEWAY_GRPC_PORT=50052

# Monitoring
METRICS_PORT=9090

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CORS_ORIGIN=*

# Bootstrap
BOOTSTRAP_DOMAIN=free.facebook.com.maranet.app

# Subscription Plans (KES)
PLAN_HOURLY_PRICE=10
PLAN_DAILY_PRICE=30
PLAN_WEEKLY_PRICE=150
PLAN_MONTHLY_PRICE=500
